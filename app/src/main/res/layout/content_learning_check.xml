<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".activity.learning.LearningCheckActivity">

    <!-- Root frame so the "Correct!" blob can float over the whole screen -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Main content column -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Language direction line -->
            <TextView
                android:id="@+id/learning_check_lang_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Translate from English to Polish" />

            <!-- Horizontal divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Flashcard word (large, left-aligned) -->
            <TextView
                android:id="@+id/learning_check_word_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingMultiplier="1.1"
                tools:text="Sample flashcard word" />

            <!-- Small category label below word -->
            <TextView
                android:id="@+id/learning_check_category_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="(Category)" />

            <!-- Answer input — taller than before, subtle grey fill, no outline -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_learning_check_edit_text"
                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:boxBackgroundColor="#EBEBEB"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintEnabled="false"
                app:endIconMode="clear_text"
                app:endIconTint="?attr/colorOnSurfaceVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/learning_check_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:gravity="center"
                    android:textSize="26sp"
                    android:inputType="text|textNoSuggestions|textVisiblePassword"
                    android:importantForAutofill="no"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Action buttons row: Finish | Skip | Check -->
            <LinearLayout
                android:id="@+id/learning_check_buttons_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_finish"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/learning_check_btn_finish" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_skip"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/learning_check_btn_skip" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_check"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/learning_check_btn_check" />

            </LinearLayout>

            <!-- Horizontal divider below buttons -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Status card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/status_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/learning_check_status_title"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/status_correct_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Correct: 0" />

                    <TextView
                        android:id="@+id/status_total_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="Total: 0" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- "Correct!" blob overlay — centred over the input field area, hidden by default -->
        <FrameLayout
            android:id="@+id/correct_popup_container"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center_horizontal|top"
            android:layout_marginTop="160dp"
            android:visibility="gone"
            android:elevation="8dp">

            <!-- Green blob background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/correct_blob_bg" />

            <!-- "Correct!" label -->
            <TextView
                android:id="@+id/correct_popup_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/learning_check_correct_popup"
                android:textSize="36sp"
                android:textStyle="bold|italic"
                android:textColor="@android:color/white"
                android:fontFamily="sans-serif-condensed" />

        </FrameLayout>

    </FrameLayout>
</ScrollView>
