<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_edit_flashcard_word"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_flashcard_et_word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/add_new_flashcard_word"
            android:windowSoftInputMode="stateAlwaysVisible" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_edit_flashcard_translation"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_flashcard_et_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/add_new_flashcard_translation"
            android:windowSoftInputMode="stateAlwaysVisible" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
